// prisma/schema.prisma
// Database schema for eCommerce Order Profitability Tracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  skus   SKU[]
  orders Order[]

  @@map("users")
}

// ─── SKU Pricing Table ───────────────────────────────────────────────────────
model SKU {
  id            Int      @id @default(autoincrement())
  skuId         String   // e.g. "0803cbc27"
  purchasePrice Float    // Cost price you paid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([skuId, userId]) // one SKU per user
  @@map("skus")
}

// ─── Merged Order Record ─────────────────────────────────────────────────────
model Order {
  id              Int      @id @default(autoincrement())

  // From both reports (JOIN KEY)
  orderItemId     String   // ORDER ITEM ID / Order item ID

  // From Pickup Report
  orderId         String?  // Order Id
  skuId           String?  // SKU
  dispatchDate    DateTime? // Dispatch by date

  // From Settlement Report
  bankSettlement  Float?   // Bank Settlement Value (Rs.)
  paymentDate     DateTime? // Payment Date

  // Calculated
  purchasePrice   Float?   // Pulled from SKU table at merge time
  profit          Float?   // bankSettlement - purchasePrice

  // Status flags
  hasPickup       Boolean  @default(false) // exists in pickup report
  hasSettlement   Boolean  @default(false) // exists in settlement report
  isMatched       Boolean  @default(false) // exists in both

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, userId]) // no duplicates per user
  @@map("orders")
}
